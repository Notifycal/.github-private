{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base"],
  "dependencyDashboard": true,
  "labels": ["dependencies"],
  "gitIgnoredAuthors": [
    "github-actions@github.com"
  ],
  "packageRules": [
    {
      "matchManagers": ["terraform"],
      "commitMessagePrefix": "fix(deps):",
      "labels": ["dependencies", "terraform"],
      "groupName": "Terraform Modules & Providers",
      "schedule": ["after 9am on Monday"],
      "dependencyDashboardApproval": false
    },
    {
      "matchManagers": ["github-actions"],
      "commitMessagePrefix": "ci(deps):",
      "labels": ["dependencies", "ci", "github-actions"],
      "groupName": "Github-actions",
      "schedule": ["after 9am on Monday"],
      "dependencyDashboardApproval": false
    },
    {
      "matchManagers": ["npm"],
      "matchDepTypes": ["dependencies", "peerDependencies"],
      "commitMessagePrefix": "fix(deps):",
      "labels": ["dependencies", "node", "npm"],
      "groupName": "Node.js Dependencies"
    },
    {
      "matchManagers": ["npm"],
      "commitMessagePrefix": "fix(deps):",
      "labels": ["dependencies", "node", "npm"],
      "groupName": "@notifycal/shared and zod",
      "matchPackageNames": [
        "zod",
        "@notifycal/shared"
      ]
    },
    {
      "matchManagers": ["npm"],
      "commitMessagePrefix": "fix(deps):",
      "labels": ["dependencies", "node", "npm", "aws"],
      "groupName": "AWS packages",
      "matchPackagePatterns": [
        "^@aws-*"
      ]
    },
    {
      "matchManagers": ["npm"],
      "commitMessagePrefix": "fix(deps):",
      "labels": ["dependencies", "node", "npm", "middy"],
      "groupName": "Middy middleware packages",
      "matchPackagePatterns": [
        "^@middy-*"
      ]
    },
    {
      "matchManagers": ["npm"],
      "commitMessagePrefix": "fix(deps):",
      "labels": ["dependencies", "node", "npm", "storybook"],
      "groupName": "Storybook middleware packages",
      "matchPackagePatterns": [
        "^@storybook-*"
      ],
      "matchPackageNames": [
        "storybook",
        "eslint-plugin-storybook",
        "@chromatic-com/storybook"
      ]
    },
    {
      "matchManagers": ["npm"],
      "matchDepTypes": ["devDependencies"],
      "commitMessagePrefix": "chore(dev-deps):",
      "labels": ["dependencies", "node", "npm"],
      "groupName": "Node.js Dev Dependencies"
    },
    {
      "matchManagers": ["nvm"],
      "enabled": false
    },
    {
      "matchManagers": ["pipenv"],
      "commitMessagePrefix": "fix(deps):",
      "labels": ["dependencies", "python"],
      "groupName": "Python (Pipenv) Dependencies",
      "schedule": ["after 9am on Monday"],
      "dependencyDashboardApproval": false
    },
    {
      "matchUpdateTypes": ["major"],
      "separateMajorMinor": true,
      "separateMultipleMajor": true
    }
  ],
  "regexManagers": [
    {
      "fileMatch": ["^/modules/.+\\.tf$"],
      "matchStrings": [
        "source\\s*=\\s*\"(?<depName>[^\"]+)\"[\\s\\S]*?version\\s*=\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "terraform-module",
      "depNameTemplate": "{{depName}}",
      "versioningTemplate": "semver"
    },
    {
      "fileMatch": ["^/tf/.+\\.tf$"],
      "matchStrings": [
        "source\\s*=\\s*\"(?<depName>[^\"]+)\"[\\s\\S]*?version\\s*=\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "terraform-module",
      "depNameTemplate": "{{depName}}",
      "versioningTemplate": "semver"
    }
  ],
  "hostRules": [
    {
      "matchHost": "https://npm.pkg.github.com/",
      "hostType": "npm",
      "token": "{{ secrets.RENOVATE_GITHUB_COM_TOKEN }}"
    }
  ],
  "npmrc": "@notifycal:registry=https://npm.pkg.github.com/"
}
